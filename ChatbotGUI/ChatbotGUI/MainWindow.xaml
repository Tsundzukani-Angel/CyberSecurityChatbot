<Window x:Class="ChatbotGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ChatbotGUI"
        mc:Ignorable="d"
        Background="#0d1117"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Label Content="CBOT CYBERSECURITY CHATBOT"
               Foreground="ForestGreen"
               FontFamily="Consolas"
               FontSize="24"
               FontWeight="Bold"
               HorizontalAlignment="Center"
               VerticalAlignment="Top"
               Margin="0,10,0,0"/>
   
        <RichTextBox x:Name="rtbChat"
                     Margin="20,70,20,100"
                     Background="Black"
                     Foreground="Lime"
                     BorderBrush="Lime"
                     FontFamily="Consolas"
                     FontSize="14"
                     IsReadOnly="True"/>

        <TextBox x:Name="txtInput"
                 KeyDown="txtInput_KeyDown"
                 Height="35"
                 Margin=" 20,0,120,20"
                 VerticalAlignment="Bottom"
                 Background="#161b22"
                 Foreground="White"
                 BorderBrush="Lime"
                 FontFamily="Consolas"
                 FontSize="14" />
        
        <Button x:Name="btnSend"
                Content="SEND"
                Width="80"
                Height="35"
                Margin="0,0,20,20"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Right"
                Background="LightGreen"
                Foreground="Black"
                FontWeight="Bold" 
                Click="btnSend_Click"
                />

        <CheckBox x:Name="chkVoice"
                  Content="Voice Enabled"
                  Margin="20,10,0,0"
                  Foreground="AliceBlue"
                  FontWeight="Bold"
                  IsChecked="True"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Top"/>

    </Grid>
</Window>
