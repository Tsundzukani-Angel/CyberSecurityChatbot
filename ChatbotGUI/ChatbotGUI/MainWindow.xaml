<Window x:Class="ChatbotGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ChatbotGUI"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Background="DarkGray">
        <Label Content="CBOT CYBERSECURITY CHATBOT"
               Foreground="Chartreuse"
               FontFamily="Consolas"
               FontSize="24"
               FontWeight="Bold"
               HorizontalAlignment="Center"
               VerticalAlignment="Top"
               Margin="0,10,0,0"/>

        <RichTextBox x:Name="rtbChat"
                     Margin="20,70,20,100"
                     Background="Beige"
                     Foreground="DarkGreen"
                     FontFamily="Consolas"
                     FontSize="14"
                     IsReadOnly="True"/>

        <TextBox x:Name="txtInput"
                 Height="35"
                 Margin=" 20,0,120,20"
                 VerticalAlignment="Bottom"
                 Background="#222"
                 Foreground="White"
                 FontFamily="Consolas"
                 FontSize="14" TextChanged="txtInput_TextChanged" KeyDown="txtInput_KeyDown"/>
        
        <Button x:Name="btnSend"
                Content="SEND"
                Width="80"
                Height="35"
                Margin="0,0,20,20"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Right"
                Background="LightGreen"
                Foreground="Black"
                FontWeight="Bold" 
                Click="btnSend_Click"
                />
    </Grid>
</Window>
